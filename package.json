{
  "name": "siyuan-homepage",
  "version": "4.5.5",
  "type": "module",
  "description": "Provides personalized homepage layout and rich functional modules.",
  "repository": "https://github.com/Glaube-TY/siyuan-homepage",
  "homepage": "https://github.com/Glaube-TY/siyuan-homepage",
  "packageManager": "pnpm@8.15.9",
  "author": "Glaube-TY",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development VITE_SOURCEMAP=inline vite build --watch",
    "build": "pnpm build:feishu-gateway && cross-env NODE_ENV=production vite build",
    "build:feishu-gateway": "node --no-warnings ./scripts/chat-action-feishu-gateway/build-feishu-gateway.js",
    "make-link": "node --no-warnings ./scripts/make_dev_link.js",
    "make-link-win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/elevate.ps1 -scriptPath ./scripts/make_dev_link.js",
    "update-version": "node --no-warnings ./scripts/update_version.js",
    "release": "node --no-warnings ./scripts/release.js",
    "make-install": "pnpm build && node --no-warnings ./scripts/make_install.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "cross-env": "^10.1.0",
    "esbuild": "0.25.12",
    "eslint": "^9.17.0",
    "fast-glob": "^3.2.12",
    "glob": "^13.0.6",
    "globals": "^15.13.0",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.8",
    "rollup-plugin-livereload": "^2.0.5",
    "sass-embedded": "^1.89.2",
    "siyuan": "1.2.0",
    "svelte": "^5.55.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^4.0.1",
    "vite-plugin-zip-pack": "^1.0.5"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@floating-ui/dom": "^1.7.4",
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "@lucide/svelte": "^1.21.0",
    "ai": "^6.0.158",
    "ajv": "^8.20.0",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.2.6",
    "echarts": "^5.6.0",
    "echarts-wordcloud": "^2.1.0",
    "elliptic": "^6.6.1",
    "howler": "^2.2.4",
    "jszip": "^3.10.1",
    "mousetrap": "^1.6.5",
    "music-metadata": "^11.13.0",
    "quill": "^2.0.2",
    "siyuan-kit-svelte": "^0.1.3",
    "sortablejs": "^1.15.6",
    "svelte-multiselect": "^11.6.4",
    "swiper": "^12.0.3",
    "tyme4ts": "^1.3.9",
    "uapi-sdk-typescript": "0.1.4",
    "zod": "^4.4.1"
  }
}
